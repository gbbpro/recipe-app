generator client{
    provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Recipe {
  id                 Int       @id @default(autoincrement())
  name               String
  filename           String    @unique
  ingredientSections Json
  instructions       String[]
  tags               String[]
  isFavorite         Boolean   @default(false)
  notes              String?
  userId             String?   // null = global recipe, string = user's personal recipe
  isGlobal           Boolean   @default(false) // true = starter recipe everyone can see
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model MealPlan {
  id          Int      @id @default(autoincrement())
  weekStart   DateTime
  dayOfWeek   Int
  mealType    String
  recipeId    Int
  userId      String   // meal plans always belong to a user
  createdAt   DateTime @default(now())

  @@unique([weekStart, dayOfWeek, mealType, userId])
}
